rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Estructura del cuadrante: solo lectura para el equipo,
    // escritura únicamente para el administrador (usuario real de Firebase Auth)
    match /cuadrante/datos {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == 'mgXnoEDMHuc4mja8mKkyKvf87IH2'
        && request.resource.data.keys().hasOnly(['personas', 'semanas', 'historico', 'tareas', 'updatedAt'])
        && request.resource.data.personas is list
        && request.resource.data.semanas is list
        && request.resource.data.tareas is list;
    }
    // Todo lo demás, cerrado (los checks se eliminaron de la app)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
